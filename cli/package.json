{
    "name": "cfkit",
    "version": "0.1.14",
    "description": "CLI to install claude-finance-kit plugin for AI coding assistants",
    "type": "module",
    "bin": {
        "cfkit": "./dist/index.js"
    },
    "files": [
        "dist",
        "assets"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "sync": "node dist/scripts/sync-assets.js",
        "bump": "node dist/scripts/bump-version.js"
    },
    "keywords": [
        "claude",
        "cursor",
        "copilot",
        "finance",
        "vietnam",
        "stock",
        "ai",
        "plugin"
    ],
    "author": "hongbietcode",
    "license": "MIT",
    "dependencies": {
        "commander": "^12.1.0",
        "chalk": "^5.3.0",
        "ora": "^8.1.1",
        "prompts": "^2.4.2"
    },
    "devDependencies": {
        "@types/node": "^22.10.1",
        "@types/prompts": "^2.4.9",
        "typescript": "^5.7.2"
    }
}