{
    "name": "claude-finance-kit-cli",
    "version": "0.1.22",
    "description": "CLI to install claude-finance-kit plugin for AI coding assistants",
    "type": "module",
    "bin": {
        "claude-finance-kit": "./dist/index.js"
    },
    "files": [
        "dist",
        "assets",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "prepack": "node dist/scripts/resolve-symlinks.js resolve",
        "postpack": "node dist/scripts/resolve-symlinks.js restore",
        "bump": "node dist/scripts/bump-version.js",
        "package": "node dist/scripts/package-plugin.js"
    },
    "keywords": [
        "claude",
        "cursor",
        "copilot",
        "finance",
        "vietnam",
        "stock",
        "ai",
        "plugin"
    ],
    "author": "hongbietcode",
    "license": "MIT",
    "dependencies": {
        "commander": "^12.1.0",
        "chalk": "^5.3.0",
        "ora": "^8.1.1",
        "prompts": "^2.4.2"
    },
    "devDependencies": {
        "@types/node": "^22.10.1",
        "@types/prompts": "^2.4.9",
        "typescript": "^5.7.2"
    }
}